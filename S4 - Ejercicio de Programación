#include <stdio.h>
 #include <string.h>

// --- DEFINICIONES ---
 #define MAX_PRODUCTOS 10
 #define MAX_NOMBRE 50

// Prototipos de funciones
 void ingresarDatos(char nombres[MAX_PRODUCTOS][MAX_NOMBRE], float precios[], int cantidades[], int n);
 float calcularTotal(float precios[], int cantidades[], int n);
 void encontrarExtremos(char nombres[MAX_PRODUCTOS][MAX_NOMBRE], float precios[], int n);
 float calcularPromedio(float precios[], int n);
 void buscarProducto(char nombres[MAX_PRODUCTOS][MAX_NOMBRE], float precios[], int n);
 int calcularUnidadesTotales(int cantidades[], int n);

// --- BLOQUE PRINCIPAL ---
 int main() {
 char sucursal[20];
 char nombres[MAX_PRODUCTOS][MAX_NOMBRE]; 
 float precios[MAX_PRODUCTOS]; 
 int cantidades[MAX_PRODUCTOS]; 
 int n;

 printf("--- SISTEMA DE INVENTARIO PARA TIENDA ---\n");
 printf("Ingrese el nombre de la sucursal (Norte, Centro, Sur): ");
 scanf("%19s", sucursal); // Limitamos el input para evitar desbordamiento

 printf("¿Cuantos productos desea ingresar? (Maximo %d): ", MAX_PRODUCTOS);
 scanf("%d", &n);

 if (n > MAX_PRODUCTOS) {
 n = MAX_PRODUCTOS;
 }
 if (n <= 0) {
 printf("Cantidad no valida.\n");
 return 0;
 }

 ingresarDatos(nombres, precios, cantidades, n);

 printf("\n========================================");
 printf("\nREPORTE DE INVENTARIO - SUCURSAL %s", sucursal);
 printf("\n========================================\n");

 printf("1. Valor total del inventario: $%.2f\n", calcularTotal(precios, cantidades, n));

 printf("2. Analisis de precios extremos:\n");
 encontrarExtremos(nombres, precios, n);

 printf("3. Precio promedio de productos: $%.2f\n", calcularPromedio(precios, n));

 // Corregido: antes decía 'quantities'
 printf("4. Total de unidades en stock: %d\n", calcularUnidadesTotales(cantidades, n));

 buscarProducto(nombres, precios, n);

 return 0;
 }

// --- IMPLEMENTACIÓN DE LAS FUNCIONES ---

void ingresarDatos(char nombres[MAX_PRODUCTOS][MAX_NOMBRE], float precios[], int cantidades[], int n) {
 for (int i = 0; i < n; i++) {
 printf("\nProducto #%d:\n", i + 1);
 printf(" Nombre: ");
 scanf("%s", nombres[i]);
 printf(" Precio: ");
 scanf("%f", &precios[i]);
 printf(" Cantidad: ");
 scanf("%d", &cantidades[i]);
 }
 }

float calcularTotal(float precios[], int cantidades[], int n) {
 float total = 0;
 for (int i = 0; i < n; i++) {
 total += (precios[i] * cantidades[i]);
 }
 return total;
 }

void encontrarExtremos(char nombres[MAX_PRODUCTOS][MAX_NOMBRE], float precios[], int n) {
 int posCaro = 0;
 int posBarato = 0;

 for (int i = 1; i < n; i++) {
 if (precios[i] > precios[posCaro]) {
 posCaro = i;
 }
 if (precios[i] < precios[posBarato]) {
 posBarato = i;
 }
 }
 printf(" - Mas caro: %s ($%.2f)\n", nombres[posCaro], precios[posCaro]);
 printf(" - Mas barato: %s ($%.2f)\n", nombres[posBarato], precios[posBarato]);
 }

float calcularPromedio(float precios[], int n) {
 float suma = 0;
 if (n == 0) return 0;
 for (int i = 0; i < n; i++) {
 suma += precios[i];
 }
 return suma / n;
 }

void buscarProducto(char nombres[MAX_PRODUCTOS][MAX_NOMBRE], float precios[], int n) {
 char nombreBusqueda[MAX_NOMBRE];
 int encontrado = 0;

 printf("\n--- BUSQUEDA DE PRODUCTO ---");
 printf("\nIngrese nombre a buscar: ");
 scanf("%s", nombreBusqueda);

 for (int i = 0; i < n; i++) {
 if (strcmp(nombres[i], nombreBusqueda) == 0) {
 printf("Encontrado: El precio de '%s' es $%.2f\n", nombres[i], precios[i]);
 encontrado = 1;
 break;
 }
 }
 if (!encontrado) {
 printf("No se encontro el producto '%s'.\n", nombreBusqueda);
 }
 }

int calcularUnidadesTotales(int cantidades[], int n) {
 int totalUnidades = 0;
 for (int i = 0; i < n; i++) {
 totalUnidades += cantidades[i];
 }
 return totalUnidades;
 }
